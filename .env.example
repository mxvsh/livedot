# Server
PORT=5550
NODE_ENV=development
DATABASE_PATH=./packages/db/data/livedot.db

# Cloud mode — enables OAuth, sets default maxWebsites=1 per user
LIVEDOT_CLOUD=false

# OAuth — only used when LIVEDOT_CLOUD=true
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:5550

# Umami Analytics (optional — injected into index.html at build time)
VITE_UMAMI_URL=
VITE_UMAMI_WEBSITE_ID=

# Limits (defaults applied to new users/websites)
DEFAULT_MAX_USER_SIGNUP=1     # max accounts that can register
DEFAULT_MAX_WEBSITES=0        # max websites per user (0 = unlimited)
DEFAULT_MAX_CONNECTIONS=1000  # max concurrent visitors tracked per website
