---
import { getDocsNavItems } from "../../lib/docs";

interface SidebarItem {
  title: string;
  description: string;
  href: string;
}

interface Props {
  activeHref?: string;
}

const { activeHref } = Astro.props as Props;
const items: SidebarItem[] = await getDocsNavItems();
---

<nav class="space-y-2">
  {items.map((item) => (
    <a
      href={item.href}
      aria-current={activeHref === item.href ? "page" : undefined}
      class:list={[
        "block border-l-2 py-2 pl-4 transition-colors",
        activeHref === item.href
          ? "border-primary text-white"
          : "border-white/10 text-on-surface-variant hover:border-primary/40 hover:text-white",
      ]}
    >
      <div class="text-sm font-medium tracking-[-0.02em]">{item.title}</div>
      <p class="mt-1 text-xs leading-5">{item.description}</p>
    </a>
  ))}
</nav>
