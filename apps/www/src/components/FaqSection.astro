---
import { faqItems } from "../data/site";
---

<section id="faq" class="mx-auto max-w-5xl px-6 py-32">
  <div class="mb-16 text-center">
    <span class="mb-6 inline-block border border-white/10 bg-white/4 px-3 py-1 font-mono text-xs tracking-[0.35em] text-primary">
      FAQ
    </span>
    <h2 class="mb-4 font-headline text-4xl font-bold tracking-tight md:text-5xl">
      Questions teams ask before they ship.
    </h2>
    <p class="mx-auto max-w-2xl text-lg text-on-surface-variant">
      Enough detail to evaluate the product quickly, without turning the page into a knowledge base.
    </p>
  </div>

  <div class="space-y-4">
    {faqItems.map((item) => (
      <details class="group rounded-lg border border-white/8 bg-surface-container px-6 py-5">
        <summary class="flex cursor-pointer list-none items-center justify-between gap-6 font-headline text-xl font-medium tracking-tight">
          <span>{item.question}</span>
          <span class="text-primary transition-transform group-open:rotate-45">+</span>
        </summary>
        <p class="pt-4 text-base leading-7 text-on-surface-variant">
          {item.answer}
        </p>
      </details>
    ))}
  </div>
</section>
