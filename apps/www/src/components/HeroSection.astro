---
const pulseDots = [
  "top-1/3 left-1/4 h-2 w-2",
  "left-1/2 top-1/2 h-1.5 w-1.5",
  "top-1/4 right-1/3 h-2 w-2",
  "bottom-1/3 right-1/4 h-1 w-1",
];
---

<section class="relative flex min-h-screen items-center justify-center overflow-hidden pt-20">
  <div class="absolute inset-0 z-0 opacity-40">
    <div class="hero-gradient absolute inset-0"></div>
    <img
      class="h-full w-full object-cover grayscale mix-blend-luminosity"
      src="https://lh3.googleusercontent.com/aida-public/AB6AXuAfuEd-GLFJvyj5E7DJobrJnmMXuA0Ze9mIHykODXSxSHuJbBkGEA9W3TQdrs71ZtUu6aK4sdXH8FRL6VhFp6OjxUWmfrl-ihsTAW3zP-VN1tBkgfPIy0SMIEU_NEiF2EtuyockSkHWs4dD3Z12iP-lGF802BCrxKnEw5FWd4Y5c80UNtcF4xfCTqAybkqaxKmkdSSmgt3HiCiB7V0eudmUkRYXLG7ArDEQ2Nwu6W_vYLOdbtxaDoG_zODv-MZ_l4TzmQbeuxvsCA"
      alt="Abstract dark world map with neon glowing connection points"
    />
  </div>

  <div class="pointer-events-none absolute inset-0">
    {pulseDots.map((classes) => <div class:list={["pulse-dot absolute rounded-full bg-primary", classes]}></div>)}
  </div>

  <div class="relative z-10 mx-auto max-w-5xl px-6 text-center">
    <p class="mb-6 inline-flex items-center gap-3 border border-white/10 bg-white/4 px-4 py-2 text-xs uppercase tracking-[0.35em] text-on-surface-variant backdrop-blur">
      <span class="h-2 w-2 rounded-full bg-primary pulse-dot"></span>
      Real-time observability
    </p>

    <h1 class="mb-8 font-headline text-5xl font-bold leading-[0.9] tracking-[-0.08em] md:text-7xl lg:text-8xl">
      See users live <br />
      on the map <span class="text-primary">in real time.</span>
    </h1>

    <p class="mx-auto max-w-2xl text-lg leading-8 text-on-surface-variant md:text-xl">
      Drop in one script and see active sessions pulse across a living map. Built for teams that want signal now, not dashboard archaeology later.
    </p>

    <div class="mt-12 flex flex-col items-center justify-center gap-6 md:flex-row">
      <a
        href="#installation"
        class="rounded-md bg-primary px-10 py-4 font-headline text-lg font-bold tracking-tight text-on-primary-container transition-all hover:shadow-[0_0_20px_rgba(174,252,45,0.3)]"
      >
        Get Started
      </a>
      <a
        href="https://github.com/mxvsh/livedot"
        class="rounded-md border border-outline-variant px-10 py-4 font-headline text-lg font-bold tracking-tight text-on-surface transition-all hover:bg-surface-variant"
      >
        GitHub
      </a>
    </div>
  </div>
</section>
